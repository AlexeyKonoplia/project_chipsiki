# Copy to .env and adjust for your environment.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=reviews

# IMPORTANT: set a long random value in production.
# Generate one with:  openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-secret

# Comma-separated usernames that automatically get admin rights.
ADMIN_USERNAMES=koh0

# Public port for the site (nginx). Use 80 on a server, 8080 locally.
FRONTEND_PORT=8080
